# AI Opener Configuration
# Copy this file to .env and customize

# Port to listen on (default: 3000)
PORT=3000

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Target protocol (http or https) - default: https
TARGET_PROTOCOL=https

# Target backend host to forward requests to
TARGET_HOST=localhost

# Target backend port to forward requests to
# Defaults to 443 for https, 8080 for http
TARGET_PORT=443
