# AI Opener Configuration
# Copy this file to .env and customize

# Server Configuration
PORT=8901
LOG_LEVEL=info  # debug, info, warn, error

# Router Authentication (REQUIRED)
# Change this to a secure random string in production!
ROUTER_API_KEY=ai-opener-secret-key-change-in-production

# Destination Configuration
# Format: DEST_<NAME>_<PROPERTY>=value
# <NAME> becomes the routing key (case-insensitive)
# API keys for each destination are stored here and injected automatically

# NVIDIA API Example
DEST_NVIDIA_PROTOCOL=https
DEST_NVIDIA_HOST=integrate.api.nvidia.com
DEST_NVIDIA_PORT=443
NVIDIA_API_KEY=nvapi-your-api-key-here

# Example: Add another destination (e.g., OpenAI)
# DEST_OPENAI_PROTOCOL=https
# DEST_OPENAI_HOST=api.openai.com
# DEST_OPENAI_PORT=443
# OPENAI_API_KEY=sk-your-api-key-here

# Groq API Example
DEST_GROQ_PROTOCOL=https
DEST_GROQ_HOST=api.groq.com
DEST_GROQ_PORT=443
GROQ_API_KEY=gsk_your-api-key-here

# Example: Local backend (no API key needed)
# DEST_LOCAL_PROTOCOL=http
# DEST_LOCAL_HOST=localhost
# DEST_LOCAL_PORT=8080
